rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /workspaces/{workspaceId}/floors/{floorId} {
      allow read, delete: if true;
      allow create, update: if request.resource.data.keys().hasAll(['floorLabel', 'directions', 'savedAt'])
                             && request.resource.data.floorLabel is string
                             && request.resource.data.directions is map
                             && request.resource.data.floorLabel.size() < 40;
    }
  }
}
